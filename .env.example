# n8n
N8N_API_URL=xxx
N8N_API_KEY=xxx

# NocoDB — base URL (spoločná pre všetky bases)
NOCODB_BASE_URL=xxx

# NocoDB — MCP server ID + token per base (Settings → MCP → URL obsahuje MCP ID)
NOCODB_MCP_ID_BASE1=xxx
NOCODB_MCP_TOKEN_BASE1=xxx

# NOCODB_MCP_ID_BASE2=xxx
# NOCODB_MCP_TOKEN_BASE2=xxx

# GitHub — backup repo (auth cez gh auth login, token nie je potrebný)
GITHUB_BACKUP_REPO=xxx
