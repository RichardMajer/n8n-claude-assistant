{
  "mcpServers": {
    "n8n": {
      "type": "http",
      "url": "${N8N_BASE_URL}/mcp-server/http",
      "headers": {
        "authorization": "Bearer ${N8N_ACCESS_TOKEN}"
      }
    },
    "nocodb-techgarden": {
      "type": "http",
      "url": "${NOCODB_BASE_URL}/mcp/${NOCODB_MCP_ID_TECHGARDEN}",
      "headers": {
        "xc-mcp-token": "${NOCODB_MCP_TOKEN_TECHGARDEN}"
      }
    },
    "nocodb-efix": {
      "type": "http",
      "url": "${NOCODB_BASE_URL}/mcp/${NOCODB_MCP_ID_EFIX}",
      "headers": {
        "xc-mcp-token": "${NOCODB_MCP_TOKEN_EFIX}"
      }
    },
    "nocodb-general": {
      "type": "http",
      "url": "${NOCODB_BASE_URL}/mcp/${NOCODB_MCP_ID_GENERAL}",
      "headers": {
        "xc-mcp-token": "${NOCODB_MCP_TOKEN_GENERAL}"
      }
    },
    "nocodb-kassa": {
      "type": "http",
      "url": "${NOCODB_BASE_URL}/mcp/${NOCODB_MCP_ID_KASSA}",
      "headers": {
        "xc-mcp-token": "${NOCODB_MCP_TOKEN_KASSA}"
      }
    },
    "nocodb-skladan": {
      "type": "http",
      "url": "${NOCODB_BASE_URL}/mcp/${NOCODB_MCP_ID_SKLADAN}",
      "headers": {
        "xc-mcp-token": "${NOCODB_MCP_TOKEN_SKLADAN}"
      }
    }
  }
}
