{
  "mcpServers": {
    "n8n": {
      "command": "npx",
      "args": [
        "-y",
        "supergateway",
        "--streamableHttp",
        "${N8N_BASE_URL}/mcp-server/http",
        "--header",
        "authorization:Bearer ${N8N_API_KEY}"
      ]
    },
    "nocodb-techgarden": {
      "command": "npx",
      "args": ["mcp-remote", "${NOCODB_BASE_URL}/mcp/${NOCODB_MCP_ID_TECHGARDEN}", "--header", "xc-mcp-token: ${NOCODB_MCP_TOKEN_TECHGARDEN}"]
    },
    "nocodb-efix": {
      "command": "npx",
      "args": ["mcp-remote", "${NOCODB_BASE_URL}/mcp/${NOCODB_MCP_ID_EFIX}", "--header", "xc-mcp-token: ${NOCODB_MCP_TOKEN_EFIX}"]
    },
    "nocodb-general": {
      "command": "npx",
      "args": ["mcp-remote", "${NOCODB_BASE_URL}/mcp/${NOCODB_MCP_ID_GENERAL}", "--header", "xc-mcp-token: ${NOCODB_MCP_TOKEN_GENERAL}"]
    },
    "nocodb-kassa": {
      "command": "npx",
      "args": ["mcp-remote", "${NOCODB_BASE_URL}/mcp/${NOCODB_MCP_ID_KASSA}", "--header", "xc-mcp-token: ${NOCODB_MCP_TOKEN_KASSA}"]
    },
    "nocodb-skladan": {
      "command": "npx",
      "args": ["mcp-remote", "${NOCODB_BASE_URL}/mcp/${NOCODB_MCP_ID_SKLADAN}", "--header", "xc-mcp-token: ${NOCODB_MCP_TOKEN_SKLADAN}"]
    }
  }
}
